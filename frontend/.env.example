# ─────────────────────────────────────────────────────────────────────────────
# Postpin dashboard (Next.js) — environment template
# Copy to `.env.local` (dev) or set in your host's env (production).
# NEXT_PUBLIC_* is baked in at build time — rebuild after changing anything.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Postpin API, INCLUDING the /v1 prefix.
# Used by the browser API client, server-side stats/blog fetches,
# and invoice PDF downloads.
#   dev:  http://localhost:4000/v1
#   prod: https://api.postpin.in/v1
NEXT_PUBLIC_API_URL=https://api.postpin.in/v1

# Public site origin — drives canonical URLs, sitemap.xml, robots.txt,
# Open Graph URLs, JSON-LD and displayed contact emails.
# MUST match the domain the site is actually served on.
NEXT_PUBLIC_SITE_URL=https://postpin.in

# Google Analytics 4 measurement ID (tag loads in production builds only).
NEXT_PUBLIC_GA_ID=G-QJXXK2S5R6

# Google Tag Manager container ID — OPTIONAL. Set this only if you manage tags
# through GTM; then add the GA4 tag inside the container (the direct GA4 tag
# above is skipped automatically to avoid double-counting).
#NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Optional overrides — defaults derive from NEXT_PUBLIC_SITE_URL:
# Display-only API base shown in docs/code samples (default: https://api.<site-host>/v1)
#NEXT_PUBLIC_API_DISPLAY_URL=https://api.postpin.in/v1
# Contact + support emails shown on the site (default: hello@/support@ <site-host>)
#NEXT_PUBLIC_CONTACT_EMAIL=hello@postpin.in
#NEXT_PUBLIC_SUPPORT_EMAIL=support@postpin.in
