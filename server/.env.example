NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
WEB_ORIGIN=http://localhost:3000

# MongoDB — use a DEDICATED database for Postpin (never another app's db).
MONGODB_URI=mongodb://USER:PASSWORD@127.0.0.1:27017/postpin?authSource=admin
MONGODB_DB=postpin

# Redis — used from Milestone 2.
REDIS_URL=redis://localhost:6379

# Auth / JWT (EdDSA). Run `npm run gen-keys` to fill JWT_PRIVATE_KEY / JWT_PUBLIC_KEY in .env.
JWT_KID=2026-q3
JWT_ISSUER=https://api.postpin.local
JWT_AUDIENCE=postpin-dashboard
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

COOKIE_DOMAIN=
COOKIE_SECURE=false

ARGON_MEMORY_KIB=19456
ARGON_TIME_COST=2
ARGON_PARALLELISM=1

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Postpin <no-reply@postpin.local>

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

SEED_ADMIN_EMAIL=admin@postpin.dev
SEED_ADMIN_PASSWORD=change-me

# JWT_PRIVATE_KEY / JWT_PUBLIC_KEY are appended by `npm run gen-keys`
