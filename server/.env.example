# ─────────────────────────────────────────────────────────────────────────────
# Postpin API — environment template (production-oriented)
# Copy to `.env` and fill in. Every variable below is read by src/config/env.ts —
# nothing else is consulted. The server FAILS FAST at boot on invalid config.
# Dev values are noted in comments where they differ.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production                     # development | test | production
PORT=4000
LOG_LEVEL=info                          # dev: debug

# Exact origin of the dashboard — CORS allows this ONE origin with credentials
# (never "*"). Dev: http://localhost:3000
# IMPORTANT: the site is served at postpin.creatibyte.in; make nginx 301-redirect
# www.postpin.creatibyte.in → postpin.creatibyte.in so the browser only ever
# calls the API from this single origin (CORS + cookies break from www).
WEB_ORIGIN=https://postpin.creatibyte.in

# ── MongoDB ──────────────────────────────────────────────────────────────────
# MUST be a database dedicated to Postpin — never share another app's db.
MONGODB_URI=mongodb://USER:PASSWORD@HOST:27017/postpin?authSource=admin
MONGODB_DB=postpin

# ── Redis ────────────────────────────────────────────────────────────────────
# Rate-limiting, monthly quota, quota-warning idempotency. The API FAILS OPEN
# if Redis is down (requests pass, limits skip) — keep it monitored in prod.
# Dev runs a Docker container on 6380: redis://localhost:6380
REDIS_URL=redis://HOST:6379

# ── API-key hashing pepper ───────────────────────────────────────────────────
# Generate on Ubuntu:   openssl rand -hex 32
# WARNING: changing this after launch invalidates EVERY issued API key — set
# once, back it up, never rotate casually.
API_KEY_PEPPER=REPLACE_WITH_OUTPUT_OF__openssl_rand_-hex_32

# ── Auth / JWT (EdDSA) ───────────────────────────────────────────────────────
# Run `npm run gen-keys` — it appends JWT_PRIVATE_KEY / JWT_PUBLIC_KEY to .env
# as single lines with literal \n. Rotate by generating a new pair under a new
# JWT_KID (old sessions then re-authenticate).
JWT_KID=2026-q3
JWT_ISSUER=https://api.postpin.creatibyte.in
JWT_AUDIENCE=postpin-dashboard
# JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
ACCESS_TOKEN_TTL=900                    # seconds (15 min)
REFRESH_TOKEN_TTL=2592000               # seconds (30 days)

# ── Cookies (refresh + CSRF) ─────────────────────────────────────────────────
# Web (postpin.creatibyte.in) and API (api.postpin.creatibyte.in) share the
# parent domain below so the CSRF cookie is readable by the dashboard and the
# refresh cookie reaches the API. Cookies MUST be Secure in prod.
# Dev: leave COOKIE_DOMAIN empty, COOKIE_SECURE=false.
COOKIE_DOMAIN=.postpin.creatibyte.in
COOKIE_SECURE=true

# ── Argon2id password hashing ────────────────────────────────────────────────
ARGON_MEMORY_KIB=19456
ARGON_TIME_COST=2
ARGON_PARALLELISM=1

# ── SMTP (verify/reset/invite/dunning/platform alerts + contact form) ────────
# Prod needs a real relay (SES/Postmark/Brevo/...). NOTE: delivery failures are
# logged but not retried — monitor your relay. Dev: localhost:1025 (mailpit).
SMTP_HOST=smtp.your-relay.example
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
SMTP_FROM=Postpin <no-reply@postpin.creatibyte.in>

# ── Razorpay (billing) ───────────────────────────────────────────────────────
# Prod = LIVE keys (rzp_live_...). RAZORPAY_WEBHOOK_SECRET must equal the secret
# you configure on the Razorpay dashboard webhook pointing at
# https://api.postpin.creatibyte.in/v1/billing/webhook
# Generate one on Ubuntu:   openssl rand -hex 24
RAZORPAY_KEY_ID=rzp_live_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_OUTPUT_OF__openssl_rand_-hex_24

# ── India Post pincode directory (data.gov.in) ───────────────────────────────
# Registered API key enables the nightly live sync (00:30 IST) + the manual
# "Run live sync" button. Empty = scheduler stays off (CSV import still works).
DATA_GOV_IN_API_KEY=REPLACE_ME
DATA_GOV_IN_PINCODE_RESOURCE=5c2f62fe-5afa-4119-a499-fec9d604d5bd

# ── Seed (scripts/seed.ts only) ──────────────────────────────────────────────
# Used ONCE when seeding a fresh database; change the password immediately
# after first login (the seeder never overwrites an existing admin).
# Generate a strong password on Ubuntu:   openssl rand -base64 18
SEED_ADMIN_EMAIL=admin@postpin.creatibyte.in
SEED_ADMIN_PASSWORD=REPLACE_WITH_OUTPUT_OF__openssl_rand_-base64_18

# ── Media uploads (avatars, ticket attachments) ──────────────────────────────
# Local-disk storage served at ${API_PUBLIC_URL}/uploads/... — in prod point
# UPLOAD_DIR at a PERSISTENT volume (single-node only) and set the public URL.
UPLOAD_DIR=/var/postpin/uploads
API_PUBLIC_URL=https://api.postpin.creatibyte.in
MAX_UPLOAD_BYTES=5242880                # 5 MB
