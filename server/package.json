{
  "name": "postpin-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Postpin API — multi-tenant shipping-rate SaaS (Fastify + MongoDB)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx src/scripts/seed.ts",
    "gen-keys": "tsx src/scripts/gen-keys.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/static": "^9.1.3",
    "@node-rs/argon2": "^2.0.2",
    "@types/pdfkit": "^0.17.6",
    "bullmq": "^5.28.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "mongoose": "^8.8.3",
    "nodemailer": "^6.9.16",
    "otplib": "^12.0.1",
    "pdfkit": "^0.19.1",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.5",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.5",
    "@vitest/coverage-v8": "^2.1.8",
    "mongodb-memory-server": "^10.1.2",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
